# ═══════════════════════════════════════
# Practik Dashboard — Environment Config
# ═══════════════════════════════════════

# ─── Core ────────────────────────────
NODE_ENV=development
PORT=3002
JWT_SECRET=practik-jwt-secret-change-in-production

# ─── Database ────────────────────────
# SQLite (dev — default, no config needed)
# PostgreSQL (prod — uncomment below)
# DATABASE_URL=postgresql://practik:password@localhost:5432/practik_dashboard

# ─── LLM Gateway ────────────────────
# Primary: Anthropic (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Fallback: OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Future: Gemini Flash (cheap tier)
# GOOGLE_API_KEY=your-gemini-key-here

# ─── Error Monitoring ───────────────
# Sentry (get DSN from sentry.io → free tier)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── External Integrations ──────────
# OneBox CRM (Phase 1.3)
# ONEBOX_API_URL=https://your-instance.onebox.ua/api
# ONEBOX_API_KEY=your-onebox-api-key

# Google Sheets (marketing sync, cost price)
# GOOGLE_SHEETS_CREDENTIALS=path/to/service-account.json

# Telegram Alerts (Phase 4)
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
